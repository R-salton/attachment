
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // ABSOLUTE MASTER BYPASS - Centralized authority list
    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'S7QoMkUQNHaok4JjLB1fFd9OI0g1' || 
        request.auth.uid == '7oiKVWSJ30Ucg0DxamaRhoxlI3G2' ||
        request.auth.uid == 'IsXXoo9z34UpjnJJTtlXhBvxHWz2' ||
        request.auth.token.email == 'nezasalton@gmail.com' ||
        request.auth.token.email == 'cboazi100@gmail.com' ||
        request.auth.token.email == 'admin@gmail.com'
      );
    }

    // Helper for role-based access with safety checks
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getRole() == role;
    }

    function isAdmin() {
      return isMasterAdmin() || isRole('ADMIN');
    }

    function isPTSLeadership() {
      return isRole('PTSLEADERSHIP');
    }

    function isCommander() {
      return isAdmin() || isPTSLeadership() || isRole('COMMANDER');
    }

    function isLeader() {
      return isCommander() || isRole('LEADER');
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /reports/{reportId} {
      // Broad read/list access for Leadership/Admin
      allow read, list: if isLeader();
      // Document-level access for owners (required for listing their own feed)
      allow read, list: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin() || isPTSLeadership());
      allow delete: if isSignedIn() && (resource.data.ownerId == reportId || resource.data.ownerId == request.auth.uid || isAdmin() || isCommander());
    }

    match /articles/{articleId} {
      allow create: if true; // Public submission terminal
      allow read, list, update, delete: if isAdmin() || isPTSLeadership();
    }
  }
}
