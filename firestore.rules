
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Master Admin bypass for core system owners only.
    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'S7QoMkUQNHaok4JjLB1fFd9OI0g1' || 
        request.auth.uid == '7oiKVWSJ30Ucg0DxamaRhoxlI3G2'
      );
    }

    // Role-based helper fetching role from the user's profile document
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getRole() == role;
    }

    function isAdmin() {
      return isMasterAdmin() || isRole('ADMIN');
    }

    function isPTSLeadership() {
      return isRole('PTSLEADERSHIP');
    }

    function isCommander() {
      return isAdmin() || isPTSLeadership() || isRole('COMMANDER');
    }

    match /users/{userId} {
      // Only Admins can manage the personnel registry.
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /reports/{reportId} {
      // PTSLEADERSHIP and Command roles can read/list all records globally.
      allow read, list: if isCommander();
      
      // Document-level access for owners.
      allow read, list: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin() || isPTSLeadership());
      allow delete: if isAdmin() || isPTSLeadership() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    match /articles/{articleId} {
      // Management access for Leadership and Admins.
      allow read, list, update, delete: if isAdmin() || isPTSLeadership();
      
      // Public terminal submission.
      allow create: if true; 
    }
  }
}
