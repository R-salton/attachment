
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    function isPTSLeadership() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'PTSLEADERSHIP';
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /reports/{reportId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /articles/{articleId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isPTSLeadership();
    }

    match /cadets/{cadetId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin() || isPTSLeadership();
    }

    match /visitor_responses/{responseId} {
      allow read, list: if isAdmin() || isPTSLeadership();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isPTSLeadership();
    }

    match /system_logs/{logId} {
      allow read, list: if isAdmin();
      allow create: if isSignedIn();
    }
  }
}
