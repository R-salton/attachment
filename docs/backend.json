
{
  "entities": {
    "Report": {
      "title": "Report",
      "description": "The main entity for an operational report.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "reportDate": { "type": "string" },
        "dayNumber": { "type": "integer" },
        "unit": { "type": "string", "enum": ["Gasabo DPU", "Kicukiro DPU", "Nyarugenge DPU", "TRS", "SIF", "TFU", "ORDERLY REPORT"] },
        "reportTitle": { "type": "string" },
        "reportingCommanderName": { "type": "string" },
        "fullText": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["DRAFT", "SUBMITTED"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "reportTitle", "createdAt", "unit"]
    },
    "Article": {
      "title": "Article",
      "description": "An article submission for the cadet magazine.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cadetName": { "type": "string" },
        "company": { "type": "string", "enum": ["Alpha", "Bravo", "Charlie"] },
        "platoon": { "type": "string", "enum": ["1", "2", "3"] },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "cadetName", "company", "platoon", "content", "createdAt"]
    },
    "VisitorResponse": {
      "title": "VisitorResponse",
      "description": "Data collection for cadet visitors.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cadetId": { "type": "string" },
        "cadetName": { "type": "string" },
        "platoon": { "type": "string", "enum": ["A1", "A2", "A3", "B1", "B2", "B3", "C1", "C2", "C3"] },
        "visitor1": { "type": "object" },
        "visitor2": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "cadetName", "platoon", "createdAt"]
    },
    "Cadet": {
      "title": "Cadet",
      "description": "A registry of all Officer Cadets.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "platoon": { "type": "string", "enum": ["A1", "A2", "A3", "B1", "B2", "B3", "C1", "C2", "C3"] }
      },
      "required": ["id", "name", "platoon"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account metadata and role assignments.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "TRAINEE", "LEADER", "COMMANDER", "PTSLEADERSHIP", "INACTIVE"] },
        "unit": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "unit"]
    },
    "SystemLog": {
      "title": "SystemLog",
      "description": "System-wide activity logs for auditing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "action", "timestamp"]
    }
  },
  "auth": {
    "providers": ["google.com", "password", "anonymous"]
  },
  "firestore": {
    "/reports/{reportId}": { "schema": "Report", "description": "Operational reports." },
    "/users/{userId}": { "schema": "UserProfile", "description": "User profiles." },
    "/articles/{articleId}": { "schema": "Article", "description": "Magazine articles." },
    "/visitor_responses/{responseId}": { "schema": "VisitorResponse", "description": "Visitor registrations." },
    "/cadets/{cadetId}": { "schema": "Cadet", "description": "Cadet registry." },
    "/system_logs/{logId}": { "schema": "SystemLog", "description": "Audit logs." }
  }
}
